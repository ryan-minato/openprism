root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{tex,bib,cls,sty}]
indent_size = 2
max_line_length = 120

[justfile, *.just]
indent_size = 4

[*.json]
indent_size = 2

[*.{yaml,yml}]
indent_size = 2

[*.md]
max_line_length = 0
trim_trailing_whitespace = false

[LICENSE]
indent_size = 4
trim_trailing_whitespace = false
